---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which trade should be booked first when building a Berwick pool?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The pool builder is the lead trade. We coordinate everything else - surveyor, engineer, electrician, gas-fitter, paver, fence certifier. If there's a retaining wall going in alongside the pool, the wall is engineered as part of the pool structure (not as a separate job), so we draw and lodge it under the same building permit. The only trade that sometimes goes in before us is the demolition crew on a knock-down-rebuild backyard."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need a separate fence certifier for AS 1926 compliance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes - fence compliance must be certified by an independent registered swimming pool barrier inspector, not by the pool builder. This is a Victorian regulatory requirement to remove the conflict-of-interest. We pre-book the inspector when the build is scheduled so the certificate is ready within 30 days of completion (the legal limit before fines apply). Cost: $400-$650, included in our quote."
      }
    },
    {
      "@type": "Question",
      "name": "Who handles the City of Casey pool register lodgement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We do. Every Victorian pool over 300mm deep must be registered with the local council within 30 days of completion. The registration includes the address, owner details, pool specifications and the AS 1926 compliance certificate. Failure to register attracts fines up to $1,800 per offence per day. We bundle the lodgement into the project so you don't have to deal with the paperwork separately."
      }
    },
    {
      "@type": "Question",
      "name": "Do you coordinate with landscapers and pavers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes - we usually do the paving and immediate hardscaping (coping, equipment slab, basic paved surround) as part of the build. For larger landscape works (extensive gardens, irrigation, lighting design, alfresco pavilions) we coordinate with your chosen landscaper or recommend one of the City of Casey landscape designers we've worked with before. The trick is sequencing - paving and fencing have to happen after the pool is filled and commissioned, not before."
      }
    },
    {
      "@type": "Question",
      "name": "How do I check a Berwick pool builder's VBA registration?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Search the public register at vba.vic.gov.au. Look for 'Domestic Builder (Limited) - Swimming Pools and Spas' as the registration class. Anyone quoting pool builds without that specific class is not legally permitted to build pools over $16K in Victoria. Our VBA number is on every quote we send. Verify before paying a deposit - it takes 30 seconds and protects you from up to six years of latent-defect risk if you accidentally hire an unregistered operator."
      }
    }
  ]
};
---
<Layout
  title="Pool Build Coordination & Casey Permits | Berwick Pools"
  description="The trades, certifiers and council references we coordinate with on Casey pool builds - surveyors, structural engineers, AS 1926 fence inspectors, City of Casey building permits, VBA registration."
  canonical="https://berwickpools.com.au/local-trades/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow">Pool build coordination &amp; references</span>
      <h1>The <span class="accent">Casey trades, certifiers and permits</span> on every pool build.</h1>
      <p class="hero-sub">
        A new pool isn&rsquo;t one trade - it&rsquo;s a coordinated team of
        surveyors, engineers, electricians, gas-fitters, pavers and certifiers
        working under a single City of Casey building permit. We coordinate all
        of it. Here&rsquo;s the regulatory map every Casey pool owner should bookmark.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
        <a class="btn btn-ghost" href="/quote/">Free pool quote</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <span class="section-eyebrow">The build team</span>
      <h2>The trades on a typical Casey pool build.</h2>
      <div class="divider"></div>
      <div style="max-width:65rem;">
        <h3>Structural engineer.</h3>
        <p>
          Designs the pier layout, footing depths, reinforcement and shell
          structure to suit your block&rsquo;s soil class. Every concrete pool
          build needs an engineer&rsquo;s certified design before the City of
          Casey will issue the building permit. We have two structural engineers
          we work with regularly on Casey jobs - both reactive-clay
          specialists. $1,200-$2,200 engineering fee, included in our quote.
        </p>

        <h3 style="margin-top:2rem;">Building surveyor &amp; permit.</h3>
        <p>
          A private registered building surveyor issues the City of Casey
          building permit, conducts mandatory inspections at footing, shell,
          fence and final stages, then issues the certificate of compliance at
          handover. Surveyor fee $1,800-$2,800, council permit fee
          $560-$900. We engage and coordinate the surveyor as part of the
          build.
        </p>

        <h3 style="margin-top:2rem;">Geotech soil tester.</h3>
        <p>
          Before a concrete pool quote is finalised we order a geotechnical
          soil report - bore holes drilled on your block, samples
          analysed, soil class confirmed under AS 2870. Tells us whether
          we&rsquo;re piering into Class M, H1, H2 or E reactive clay.
          ~$700, ordered after the site visit, before final engineering. Skipped
          on most cheap quotes - which is how shells crack.
        </p>

        <h3 style="margin-top:2rem;">Licensed plumber &amp; gas-fitter.</h3>
        <p>
          Pool plumbing (50mm PVC pressure pipe to skimmer, returns, main
          drain) is done in-house. Gas connections for a gas pool heater or
          pool-side BBQ require a licensed gas-fitter with a Victorian gas
          compliance certificate. We engage one as needed - about 15% of
          our pool builds include a gas connection.
        </p>

        <h3 style="margin-top:2rem;">Licensed electrician.</h3>
        <p>
          Pool equipment requires RCD-protected outdoor circuits, dedicated
          breakers for pump, heater and chlorinator, and underwater LED
          circuits at 12V. All pool electrical work needs a Victorian
          electrical compliance certificate. Our electrician handles the lot.
        </p>

        <h3 style="margin-top:2rem;">AS 1926.1 fence certifier (independent).</h3>
        <p>
          The pool barrier must be certified by an independent registered
          swimming pool barrier inspector - not by the pool builder. This
          is a Victorian regulatory requirement to remove conflict of interest.
          We pre-book the inspector at scheduling so the certificate is ready
          within the 30-day legal window. $400-$650.
        </p>
      </div>
    </div>
  </section>

  <section class="section" style="background:#f9fafb;">
    <div class="section-inner">
      <span class="section-eyebrow">Council, registers &amp; standards</span>
      <h2>The regulatory references for Casey pool builds.</h2>
      <div class="divider"></div>
      <div style="max-width:65rem;">
        <p>
          We point owners to these resources constantly - particularly
          the AS 1926 fence standard and the Victorian pool register
          requirements, which catch a lot of new pool owners out.
        </p>
        <ul style="margin-top:1rem;">
          <li style="margin-bottom:0.75rem;">
            <strong>City of Casey Council</strong> - building permits,
            planning overlays, pool register lodgement, fence compliance
            enforcement.
            <a href="https://www.casey.vic.gov.au/" target="_blank" rel="external noopener">casey.vic.gov.au</a>
          </li>
          <li style="margin-bottom:0.75rem;">
            <strong>Victorian Building Authority (VBA)</strong> - public
            register of licensed builders. Decks and pools over $10K must be
            built by a registered builder. Verify before paying any deposit.
            <a href="https://www.vba.vic.gov.au/" target="_blank" rel="external noopener">vba.vic.gov.au</a>
          </li>
          <li style="margin-bottom:0.75rem;">
            <strong>AS 1926.1-2012 - Safety barriers for swimming pools</strong>
            - the Australian Standard that prescribes pool fence height,
            climb zone, gap measurements and gate compliance. Re-certification
            required after any pool alteration.
            <a href="https://store.standards.org.au/" target="_blank" rel="external noopener">Standards Australia</a>
          </li>
          <li style="margin-bottom:0.75rem;">
            <strong>AS 2870 - Residential slabs and footings</strong>
            - the standard for soil-class classification (M, H1, H2, E)
            and corresponding footing engineering. The reason we order a geotech
            report on every concrete pool.
            <a href="https://store.standards.org.au/" target="_blank" rel="external noopener">Standards Australia</a>
          </li>
          <li style="margin-bottom:0.75rem;">
            <strong>Victorian Pool Register</strong> - every Victorian pool
            and spa over 300mm deep must be registered with the local council
            within 30 days of completion. Penalty up to $1,800 per offence per
            day for non-compliance.
            <a href="https://www.vba.vic.gov.au/consumers/pools-and-spas" target="_blank" rel="external noopener">VBA - Pools and Spas</a>
          </li>
          <li style="margin-bottom:0.75rem;">
            <strong>Domestic Building Insurance</strong> - mandatory home
            warranty cover for any build over $16K. Protects the owner for 6
            years 2 months against latent structural defects. Carried by any
            registered VBA pool builder.
            <a href="https://www.vmia.vic.gov.au/" target="_blank" rel="external noopener">VMIA</a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <span class="section-eyebrow">Frequently asked</span>
      <h2>How Casey pool builds get sequenced.</h2>
      <div class="divider"></div>
      <div style="max-width:65rem;">
        <h3>Permit first - always.</h3>
        <p>
          No excavation until the City of Casey building permit is issued.
          Permit takes 4-8 weeks depending on Council workload, longer
          if there are planning overlays. We lodge the moment the design is
          signed and engineering complete - that&rsquo;s the critical
          path. While we wait we order shell (fibreglass) or finalise materials
          (concrete).
        </p>
        <h3 style="margin-top:1.5rem;">Excavation only when the weather holds.</h3>
        <p>
          Casey clay turns to slurry after 30mm of rain and stops the dig for
          3-7 days. We schedule excavation in the dry window where we
          can, and we don&rsquo;t excavate into known wet weather. That&rsquo;s
          not delay - that&rsquo;s smart sequencing.
        </p>
        <h3 style="margin-top:1.5rem;">Fence and pave AFTER pool is filled.</h3>
        <p>
          The pool must be filled and commissioned before the fence
          certifier signs off (the cert is on an operational pool, not an
          empty hole) and before the paving locks in. We coordinate fill,
          commission, certify and pave in the final 1-2 weeks of the
          project.
        </p>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--ink);color:#fff;">
    <div class="section-inner" style="text-align:center;">
      <h2 style="color:#fff;">Free quote - honest Casey pool pricing.</h2>
      <p style="opacity:0.85;max-width:50rem;margin:1rem auto 2rem;">
        Concrete and fibreglass pools. Plunge pools. Full renovations and
        equipment swaps. AS 1926 fence compliance and City of Casey permits
        coordinated in-house.
      </p>
      <div class="hero-actions" style="justify-content:center;">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; (03) 9003 0108</a>
        <a class="btn btn-ghost" href="/quote/">Get a fixed quote</a>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="section-inner">
      <h2>More guides &amp; articles</h2>
      <p>Hand-picked reading from our jobs around the area.</p>
      <ul class="guides-list">
          <li><a href="/fibreglass-vs-concrete-berwick/">Fibreglass vs concrete in Berwick - the soil decides more than the brochure does</a></li>
          <li><a href="/new-pool-timeline-berwick/">A realistic 8-week new-pool timeline for Berwick - and the payment schedule that goes with it</a></li>
          <li><a href="/pool-excavation-berwick/">Pool excavation in Berwick - what Council needs, what neighbours need, and how the dig actually works</a></li>
          <li><a href="/pool-resurfacing-berwick/">Pool resurfacing in Berwick - pebble, quartz, tile and what each one really feels like</a></li>
      </ul>
    </div>
  </section>

</Layout>
