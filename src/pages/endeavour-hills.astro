---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is it worth putting a pool in an Endeavour Hills 80s-90s home?",
      "acceptedAnswer": { "@type": "Answer", "text": "For a lot of owners — yes. Endeavour Hills was built out in the 1980s and early 1990s and most of the housing stock is now hitting the 35-40 year mark where major renovations make sense. Adding a pool plus a refreshed alfresco often improves the resale value by 70-90% of the pool's build cost (industry studies put pool ROI at 60-100% depending on suburb and quality of integration). Combine it with a kitchen and bathroom reno and you get a 1990s house competing with new builds for a fraction of the rebuild cost. We do a lot of these whole-yard transformations." }
    },
    {
      "@type": "Question",
      "name": "Are Endeavour Hills blocks large enough for a pool?",
      "acceptedAnswer": { "@type": "Answer", "text": "Most are. The standard Endeavour Hills block is 550-800m² — a touch bigger than the new Cranbourne East estates and a touch smaller than Hampton Park. Plenty of room for a 7-8m pool plus paved surround plus a 4-6m grassed area. The constraint isn't usually block size; it's access. Mature gardens, brick fences and overhead power lines from the 80s-90s subdivision often mean a fibreglass crane has to swing carefully or we move to concrete." }
    },
    {
      "@type": "Question",
      "name": "What about the existing 90s pools in Endeavour Hills — can you renovate?",
      "acceptedAnswer": { "@type": "Answer", "text": "About 25% of our Endeavour Hills work is renovation rather than new build. The pebblecrete pools from the early 90s are now hitting end-of-life on the interior surface: cracking, staining, equipment failing. A full renovation — resurface to quartz or pebble, retile waterline, replace skimmer and main drain, new variable-speed pump and salt chlorinator — runs $18K-$28K and gives the pool another 25-30 years. Compared to $55K-$85K to demolish and rebuild, renovation is the smart call for most owners." }
    },
    {
      "@type": "Question",
      "name": "What's the soil like in Endeavour Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "Mixed. The original Endeavour Hills subdivision is built on Newer Volcanic basalt overlying Silurian mudstone — mostly Class M reactive clay, with patches of Class H1 in low-lying areas and pockets of stable Class A on the higher ridges. Lakeside (the newer northern estate) is more uniformly Class M. We always order a geotech report before final concrete engineering — never assume the soil class from neighbouring properties." }
    },
    {
      "@type": "Question",
      "name": "Do Endeavour Hills owners need a planning permit as well as a building permit?",
      "acceptedAnswer": { "@type": "Answer", "text": "Usually just a building permit. Endeavour Hills has very few planning overlays — no heritage, no significant landscape overlay, no bushfire management overlay across most of the suburb. That makes the permit pathway one of the cleanest in Casey: City of Casey building permit + AS 1926 fence certificate + pool register lodgement. The permit usually issues in 4-6 weeks." }
    }
  ]
};
---
<Layout
  title="Pool Builders Endeavour Hills | 80s-90s Homes, Renovation Cycle | (03) 9003 0108"
  description="Concrete and fibreglass pool builders for Endeavour Hills — Casey north, established 80s-90s housing, hitting the renovation cycle. New pools and renovation of tired 90s pebblecrete. AS 1926 fence compliance. Free on-site consultation."
  canonical="https://berwickpools.com.au/endeavour-hills/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow">Endeavour Hills &middot; Casey north &middot; established 80s&ndash;90s</span>
      <h1>Pool builders in <span class="accent">Endeavour Hills</span>.</h1>
      <p class="hero-sub">
        Endeavour Hills was built out in the 1980s and early 1990s &mdash; the
        housing stock is now hitting the 35&ndash;40 year mark where big
        renovations make sense. About 75% of our Endeavour Hills calls are new
        pool builds as part of a whole-backyard refresh; the other 25% are
        renovations of tired pebblecrete pools from the original 90s subdivision.
        Either way, we know this suburb well.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
        <a class="btn btn-ghost" href="/quote/">Book a free consultation</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <span class="section-eyebrow">Why Endeavour Hills</span>
      <h2>The Endeavour Hills pool story.</h2>
      <div class="divider"></div>
      <div style="max-width: 65rem;">
        <h3>The 80s&ndash;90s renovation cycle.</h3>
        <p>
          Houses built in the 1985&ndash;1995 boom are now 30&ndash;40 years old
          and most are about to get their first or second major renovation. Adding
          a pool plus a refreshed alfresco transforms the house from &ldquo;tired
          90s build&rdquo; to &ldquo;competitively priced family home&rdquo; without
          the cost of demolition and rebuild. Industry data puts pool ROI at
          <strong>60&ndash;100% of build cost on resale</strong> when the pool is
          integrated properly with the existing house. Done well, it&rsquo;s one
          of the best mid-budget renovations available in this suburb.
        </p>

        <h3 style="margin-top: 2rem;">Renovating an existing 90s pool.</h3>
        <p>
          A lot of Endeavour Hills homes already have a pool &mdash; original
          pebblecrete from 1990&ndash;1995, now showing its age. Surface
          cracking, hairline tile failure, leaking skimmer box, ancient
          single-speed pump that&rsquo;s costing $1,200/year in electricity.
          A <strong>full renovation</strong> (resurface to modern quartz or
          glass-bead pebble, retile waterline, replace skimmer and main drain,
          install variable-speed pump and salt chlorinator) runs
          <strong>$18K&ndash;$28K</strong> and gives the pool another 25&ndash;30
          year service life. That&rsquo;s the math: spend $22K to save the $60K
          tear-out-and-rebuild. We do it constantly.
        </p>

        <h3 style="margin-top: 2rem;">Mature-suburb access challenges.</h3>
        <p>
          Most Endeavour Hills blocks have established gardens, brick or paling
          fences, and overhead power lines from the original 80s subdivision.
          Crane access for fibreglass shells is sometimes blocked. We assess
          carefully &mdash; if the crane swing isn&rsquo;t clean, we either drop
          and reinstate a fence panel ($1.5K&ndash;$3K), trim a fence run, or
          quote concrete instead. Concrete pools are sprayed in place so they
          don&rsquo;t need shell access at all.
        </p>

        <h3 style="margin-top: 2rem;">Typical Endeavour Hills projects.</h3>
        <ul>
          <li>Full renovation of 1990s pebblecrete pool: resurface + retile + new equipment ($18K&ndash;$28K)</li>
          <li>8m &times; 4m fibreglass + travertine surround as part of whole-yard refresh ($52K&ndash;$65K)</li>
          <li>8.5m concrete pool with new alfresco pavilion behind the 90s house ($75K&ndash;$95K)</li>
          <li>Equipment swap: old single-speed pump + DE filter to VSD pump + cartridge + heat pump ($4K&ndash;$8K)</li>
          <li>Replace failed pool fence with AS 1926 compliant glass + black aluminium ($8K&ndash;$14K)</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="section-inner">
      <h2>Other Casey suburbs we cover.</h2>
      <div class="areas-grid">
        <a class="area-pill" href="/berwick/">Berwick</a>
        <a class="area-pill" href="/cranbourne/">Cranbourne</a>
        <a class="area-pill" href="/narre-warren/">Narre Warren</a>
        <a class="area-pill" href="/hampton-park/">Hampton Park</a>
        <a class="area-pill" href="/city-of-casey/">All City of Casey</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="cta-block">
        <h2>Free Endeavour Hills pool consultation.</h2>
        <p>New build, full renovation or equipment swap. Honest assessment of which makes sense.</p>
        <div class="hero-actions" style="justify-content:center;">
          <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
          <a class="btn btn-ghost" href="/quote/">Book online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
