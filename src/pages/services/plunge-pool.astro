---
import Layout from '../../layouts/Layout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Plunge Pool Build",
  "serviceType": "Compact plunge pool design and installation",
  "provider": {
    "@type": "GeneralContractor",
    "name": "Berwick Pools",
    "telephone": "+61390030108"
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "City of Casey" },
    { "@type": "City", "name": "Berwick" },
    { "@type": "City", "name": "Cranbourne" },
    { "@type": "City", "name": "Narre Warren" },
    { "@type": "City", "name": "Hampton Park" },
    { "@type": "City", "name": "Endeavour Hills" }
  ],
  "description": "Compact 3-5m deep plunge pools for small Casey backyards, courtyards and townhouses. Concrete in-situ or precast Plungie shell. Heat-pump-friendly, year-round use. Designed for cooling off, hydrotherapy and small-family use without taking up the whole yard.",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "AUD",
    "priceRange": "$25,000-$45,000",
    "description": "Typical 3.5-5m plunge pool installed, including shell, equipment, coping and commissioning. Paving and fencing additional."
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What size is a plunge pool?",
      "acceptedAnswer": { "@type": "Answer", "text": "Plunge pools are typically 3-5m long, 2-3m wide, and 1.4-1.6m deep — significantly deeper than a standard pool's shallow end. The deeper water lets adults submerge fully, which is the point: a plunge pool is for cooling off, hydrotherapy and small-family use, not for laps. Most popular sizes in Casey: 3.5m × 2.5m × 1.5m deep (smallest), 4m × 2.5m × 1.5m, 5m × 3m × 1.5m (largest). The 4 × 2.5 fits comfortably on most courtyard or townhouse blocks." }
    },
    {
      "@type": "Question",
      "name": "Can a plunge pool be used year-round?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, with a heat pump. A 9kW heat pump can hold a 4m plunge pool at 28-30°C through Casey winter for about $20-$35/week running cost (compared to $80-$150/week for a full-sized pool of the same temperature). The small water volume is the advantage — heat pumps are very efficient on plunge pools. Cover the pool with a thermal blanket when not in use and the running cost halves again. Many plunge owners swim all year, sometimes hot-tub-style at 35°C." }
    },
    {
      "@type": "Question",
      "name": "Concrete plunge or precast (Plungie) — which is better?",
      "acceptedAnswer": { "@type": "Answer", "text": "Precast Plungie shells are factory-built concrete pools delivered to your block as a single unit and craned in like a fibreglass shell. Advantages: rapid install (often 5-7 days), premium consistent finish, lower install cost. Limitations: standard sizes only, requires crane access. In-situ concrete plunge pools are built on-site like a small standard concrete pool. Advantages: any shape and depth, integrates with existing landscape features. Limitations: longer build (10-14 weeks), higher cost. For a clean rectangular plunge on a townhouse block, Plungie wins. For a unique-shaped plunge integrated into a feature wall, in-situ wins." }
    },
    {
      "@type": "Question",
      "name": "Does a plunge pool need a fence in Victoria?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — every Victorian pool over 300mm deep needs a fence to AS 1926.1-2012, regardless of size. Plunge pools are typically 1.4-1.6m deep so the full fence requirement applies. The compact footprint can actually make compliance easier — you might only need 8-12 lineal metres of fence around a 4m plunge versus 25-30 lineal metres around an 8m family pool. We design the fence layout from day one to minimise its visual impact in a small courtyard." }
    },
    {
      "@type": "Question",
      "name": "How long does a plunge pool take to build?",
      "acceptedAnswer": { "@type": "Answer", "text": "Plungie precast: 6-10 weeks from contract sign (permit 4-6 weeks, manufacture 1-2 weeks, install 1-2 weeks). In-situ concrete plunge: 10-16 weeks (permit 4-6 weeks, dig + shell 2 weeks, 28-day cure non-negotiable, finishing 2-3 weeks). The cure period is fixed even on a tiny shell — concrete reaches design strength at 28 days regardless of pool size." }
    },
    {
      "@type": "Question",
      "name": "Will a plunge pool add value to a small Casey block?",
      "acceptedAnswer": { "@type": "Answer", "text": "On small blocks (townhouses, units, courtyards under 350m²) where a full pool would dominate the yard, a plunge pool often adds more value than a standard pool because it improves the property's outdoor lifestyle without sacrificing the only patch of grass. Industry estimates suggest plunge pools return 65-90% of build cost on resale in growth-area suburbs like Berwick Waters, Cranbourne East and the Narre Warren townhouse developments. The integration with the surround matters more than the pool itself — a cheap plunge in a cheap courtyard reads as an afterthought; a well-designed plunge with proper paving and lighting reads as a feature." }
    }
  ]
};
---
<Layout
  title="Plunge Pool Builders Berwick | Compact Deep Pools | (03) 9003 0108"
  description="Plunge pool builds for Berwick, Cranbourne, Narre Warren, Hampton Park, Endeavour Hills. 3-5m compact deep pools, concrete or precast Plungie shell. Heat-pump-friendly year-round use. $25K-$45K typical. Perfect for small Casey blocks."
  canonical="https://berwickpools.com.au/services/plunge-pool/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow">Compact, deep, year-round</span>
      <h1>Plunge pools in <span class="accent">Berwick &amp; the City of Casey</span>.</h1>
      <p class="hero-sub">
        Compact 3&ndash;5m deep pools for courtyards, townhouses, small Casey
        blocks and second-pool builds. Concrete in-situ or precast Plungie shell.
        Heat-pump-friendly, year-round use. The right answer when a full-size
        pool would swallow the back yard.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
        <a class="btn btn-ghost" href="/quote/">Book a free consultation</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <h2>Plunge pool builds &mdash; the detail.</h2>
      <div style="max-width: 65rem;">
        <h3>What you get for $25K&ndash;$45K.</h3>
        <p>
          A standard 3.5&ndash;4m precast Plungie shell or 4&ndash;5m in-situ
          concrete plunge pool, 1.4&ndash;1.6m deep throughout, installed with
          variable-speed pump, cartridge filter, salt chlorinator and bullnose
          tile or precast concrete coping. Add $2K&ndash;$4K for a 9&ndash;13kW
          heat pump (the single best plunge upgrade &mdash; turns it into a
          year-round pool), $1.5K&ndash;$3K for a thermal blanket and roller,
          $2K&ndash;$5K for LED feature lighting. Paving and fencing typically
          $6K&ndash;$15K extra depending on courtyard size and access.
        </p>

        <h3 style="margin-top: 2rem;">Plungie precast shells.</h3>
        <p>
          Plungie pools are factory-precast concrete shells &mdash; manufactured
          off-site, delivered on a truck, craned into your prepared excavation
          in a single piece. We install Plungie regularly because the finish
          quality is consistent, the install timeline is tight (5&ndash;7 days
          on-site once the permit is through), and the design matches the
          contemporary townhouse aesthetic perfectly. Available in
          <strong>Plungie Original</strong> (3.5m &times; 2.5m), <strong>Studio</strong>
          (5m &times; 2.5m), and <strong>Max</strong> (6m &times; 3m). Premium
          finish, smooth concrete, in-tile coping options.
        </p>

        <h3 style="margin-top: 2rem;">In-situ concrete plunge pools.</h3>
        <p>
          For owners who want a non-standard shape, depth or integration
          with an existing landscape feature (stack-stone wall, raised deck,
          fire-pit alcove), we build the plunge pool in-situ as a small
          concrete pool. Same engineering as a full-size concrete pool
          &mdash; bored piers below the active soil zone, reinforced shell,
          28-day cure &mdash; just at a much smaller scale. Build time 10&ndash;16
          weeks. Cost $32K&ndash;$50K depending on shape, finish and feature
          integration.
        </p>

        <h3 style="margin-top: 2rem;">Why people choose plunge pools in Casey.</h3>
        <ul>
          <li><strong>Block constraint.</strong> 350&ndash;500m&sup2; townhouse or estate block where a full pool would eat the entire yard.</li>
          <li><strong>Year-round use.</strong> Small water volume + heat pump = $20&ndash;$35/week to hold 28&ndash;30&deg;C through winter. Many owners swim year-round.</li>
          <li><strong>Hydrotherapy.</strong> 1.5m depth lets adults submerge fully for stretching, recovery and shoulder/knee work that a standard 1.2m shallow end can&rsquo;t deliver.</li>
          <li><strong>Lower running cost.</strong> Smaller volume = less chemical, less filtration time, less heating. Around half the annual running cost of a full pool.</li>
          <li><strong>Cleaner install footprint.</strong> Smaller excavation, less spoil to cart away, less disruption to the courtyard or garden.</li>
        </ul>

        <h3 style="margin-top: 2rem;">Where plunge pools work best.</h3>
        <p>
          Berwick Waters townhouses, Cranbourne East and Botanic Ridge new-estate
          courtyard blocks, Lakeside townhouse developments, Officer townhouses,
          and any block where the existing landscaping is too valuable to lose.
          We do a lot of these alongside an alfresco refresh &mdash; the pool plus
          alfresco upgrade together transforms a small back yard into a serious
          entertaining zone for $50K&ndash;$70K all-in.
        </p>

        <h3 style="margin-top: 2rem;">Heat pump is the unlock.</h3>
        <p>
          A plunge pool without heating is a hot-month-only pool &mdash;
          November to March in Casey. A plunge pool with a 9kW heat pump
          (Madimack, Astralpool, Evoheat or similar) holds 28&ndash;30&deg;C
          year-round for $20&ndash;$35 per week. That single upgrade turns
          your $30K plunge into the most-used room of the house. Highly
          recommended on every plunge build &mdash; the math is overwhelming.
        </p>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="section-inner">
      <h2>Where we work.</h2>
      <div class="areas-grid">
        <a class="area-pill" href="/berwick/">Berwick</a>
        <a class="area-pill" href="/cranbourne/">Cranbourne</a>
        <a class="area-pill" href="/narre-warren/">Narre Warren</a>
        <a class="area-pill" href="/hampton-park/">Hampton Park</a>
        <a class="area-pill" href="/endeavour-hills/">Endeavour Hills</a>
        <a class="area-pill" href="/city-of-casey/">All City of Casey</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="cta-block">
        <h2>Free plunge pool consultation.</h2>
        <p>Plungie precast or in-situ concrete &mdash; honest advice on which suits your block. Fixed quote in 7&ndash;10 days.</p>
        <div class="hero-actions" style="justify-content:center;">
          <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
          <a class="btn btn-ghost" href="/quote/">Book online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
