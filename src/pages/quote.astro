---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Free Pool Design Consultation | Berwick, Casey | (03) 9003 0108"
  description="Get a free on-site pool consultation for your Berwick, Cranbourne, Narre Warren, Hampton Park or Endeavour Hills block. 60-90 min visit + fixed-price quote within 7-10 days. Concrete and fibreglass pool builds, plunge pools, renovations."
  canonical="https://berwickpools.com.au/quote/">

  <section class="hero" style="padding: 2.5rem 0 3rem;">
    <div class="hero-inner">
      <span class="hero-eyebrow">Free On-Site Consultation</span>
      <h1>Book your free pool consultation.</h1>
      <p class="hero-sub">
        Tell us about your block and what you&rsquo;d like to build. We come
        on-site for a 60&ndash;90 minute consultation, measure the yard, check
        access, look at the soil class, and walk you through concrete vs
        fibreglass honestly. Fixed-price written quote within 7&ndash;10 days.
        Free, no obligation.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="form-wrap">
        <div class="form-card">
          <form name="quote" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" action="/thanks/">
            <input type="hidden" name="form-name" value="quote" />
            <p style="display:none;"><label>Don&rsquo;t fill this out: <input name="bot-field" /></label></p>

            <label for="name">Your name</label>
            <input id="name" name="name" type="text" autocomplete="name" required />

            <label for="phone">Phone number</label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" required placeholder="04xx xxx xxx" />

            <label for="email">Email</label>
            <input id="email" name="email" type="email" autocomplete="email" required />

            <label for="suburb">Suburb / postcode</label>
            <input id="suburb" name="suburb" type="text" autocomplete="address-level2" required placeholder="e.g. Berwick 3806, Cranbourne 3977, Narre Warren 3805" />

            <label for="format">What type of pool are you considering?</label>
            <select id="format" name="format">
              <option value="not-sure">Not sure &mdash; want an honest recommendation</option>
              <option value="new-concrete">New concrete pool (custom shape, premium build)</option>
              <option value="new-fibreglass">New fibreglass pool (faster, cost-effective)</option>
              <option value="plunge-pool">Plunge pool (compact, 3&ndash;5m)</option>
              <option value="renovation">Renovate / resurface existing pool</option>
              <option value="equipment-upgrade">Equipment upgrade only (pump, filter, heater)</option>
              <option value="spa-integrated">Pool + integrated spa</option>
              <option value="lap-pool">Lap pool (8m+)</option>
            </select>

            <label for="purpose">What is it for?</label>
            <select id="purpose" name="purpose">
              <option value="family">Family swimming &mdash; kids, summer cooling</option>
              <option value="entertaining">Entertaining &mdash; pool plus alfresco zone</option>
              <option value="fitness">Fitness &mdash; serious lap swimming</option>
              <option value="hydrotherapy">Hydrotherapy / recovery</option>
              <option value="resale">Improve property value before selling</option>
              <option value="renovate-existing">Renovate existing tired pool</option>
              <option value="year-round">Year-round use (heated)</option>
              <option value="other">Other</option>
            </select>

            <label for="size">Approximate pool size</label>
            <select id="size" name="size">
              <option value="not-sure">Not sure &mdash; advise based on block</option>
              <option value="plunge">Plunge (3&ndash;5m)</option>
              <option value="small">Small family (6&ndash;7m)</option>
              <option value="medium">Standard family (7&ndash;8m)</option>
              <option value="large">Large (8&ndash;10m)</option>
              <option value="lap">Lap pool (10m+)</option>
            </select>

            <label for="soil-zone">Casey zone</label>
            <select id="soil-zone" name="soil-zone">
              <option value="established">Established Casey (Berwick south, Narre Warren, Endeavour Hills, Hampton Park) &mdash; older block, 600&ndash;1,000m&sup2;</option>
              <option value="growth">Growth-corridor estate (Berwick Waters, Eden Rise, Botanic Ridge, Marriott Waters, Cranbourne East) &mdash; newer block 500&ndash;700m&sup2;</option>
              <option value="rural-residential">Rural-residential fringe (Hampton Park south, large acreage) &mdash; 1,500m&sup2;+</option>
              <option value="townhouse">Townhouse / courtyard block &mdash; under 350m&sup2;</option>
              <option value="not-sure">Not sure / other</option>
            </select>

            <label for="timeframe">When do you want it built?</label>
            <select id="timeframe" name="timeframe">
              <option value="asap">ASAP &mdash; next 1-3 months</option>
              <option value="this-summer">Want to swim this summer (before Dec)</option>
              <option value="next-summer">Next summer (Dec onwards)</option>
              <option value="12+">12 months or longer (planning stage)</option>
              <option value="research">Just researching for now</option>
            </select>

            <label for="message">Any details? (optional)</label>
            <textarea id="message" name="message" rows="4" placeholder="Block size and shape, slope, existing pool you want renovated, known site constraints, budget range, deadline..."></textarea>

            <button class="btn btn-primary btn-block" type="submit">Send my consultation request</button>

            <p style="margin-top: 1rem; font-size: 0.85rem; color: var(--c-muted);">We reply within 1 business day. Free, no obligation.</p>
          </form>
        </div>

        <aside class="form-aside">
          <h3>Prefer to talk?</h3>

          <div class="info-row">
            <span aria-hidden="true" style="font-size:1.5rem; line-height:1;">&#9742;</span>
            <div>
              <strong>Phone</strong>
              <a href="tel:+61390030108">(03) 9003 0108</a>
              <p style="font-size:0.85rem; color:var(--c-muted); margin:0;">Mon&ndash;Sat 7am&ndash;6pm</p>
            </div>
          </div>

          <div class="info-row">
            <span aria-hidden="true" style="font-size:1.5rem; line-height:1;">&#9978;</span>
            <div>
              <strong>Service area</strong>
              <p style="margin:0;">Full City of Casey &mdash; Berwick, Cranbourne, Narre Warren, Hampton Park, Endeavour Hills, Clyde, Hallam, Officer, Beaconsfield.</p>
            </div>
          </div>

          <div class="info-row">
            <span aria-hidden="true" style="font-size:1.5rem; line-height:1;">&#10004;</span>
            <div>
              <strong>What you&rsquo;ll get</strong>
              <ul style="margin:0.4rem 0 0; padding-left:1rem; font-size:0.95rem; color:var(--c-text);">
                <li>Free on-site 60&ndash;90 min pool consultation</li>
                <li>Soil and access check at the visit</li>
                <li>Concrete vs fibreglass honest recommendation</li>
                <li>Fixed-price written quote within 7&ndash;10 days</li>
                <li>VBA-registered swimming pool builder, AS 1926 fence compliance built-in</li>
                <li>Domestic Building Insurance (6 years 2 months warranty cover)</li>
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
