---
import Layout from '../../layouts/Layout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "New Concrete Pool Build",
  "serviceType": "Custom concrete swimming pool design and construction",
  "provider": {
    "@type": "GeneralContractor",
    "name": "Berwick Pools",
    "telephone": "+61390030108"
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "City of Casey" },
    { "@type": "City", "name": "Berwick" },
    { "@type": "City", "name": "Cranbourne" },
    { "@type": "City", "name": "Narre Warren" },
    { "@type": "City", "name": "Hampton Park" },
    { "@type": "City", "name": "Endeavour Hills" }
  ],
  "description": "Fully custom sprayed-shotcrete and reinforced-concrete swimming pool design and construction for Berwick and the wider City of Casey. Any shape, depth or finish — tiled, pebble, quartz. Includes reactive-clay engineered piers, AS 1926 fence integration, full permit handling.",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "AUD",
    "priceRange": "$50,000-$90,000",
    "description": "Typical 8m × 4m custom concrete pool build, including excavation, piers, shotcrete shell, tiled coping, equipment install and commissioning. Paving, fencing and landscaping additional."
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why choose a concrete pool over fibreglass?",
      "acceptedAnswer": { "@type": "Answer", "text": "Three reasons people choose concrete: shape freedom (you can build literally any shape and depth — wet edges, beach entries, integrated spa, lap pool with raised wall), longevity (50+ year structural life vs 25-35 for fibreglass), and finish (tiled or premium pebble looks dramatically different to gelcoat). The trade-off is cost (50% more typically) and build time (3-5x longer). For owners who want a one-and-done premium build, concrete is the answer." }
    },
    {
      "@type": "Question",
      "name": "What's involved in building a concrete pool?",
      "acceptedAnswer": { "@type": "Answer", "text": "Eight stages: (1) excavation to design depth plus 200mm working clearance; (2) bored concrete piers 1.5-2.4m below the active soil zone for reactive-clay engineering; (3) reinforcing steel cage tied to the piers and shell base; (4) sprayed shotcrete or hand-poured concrete shell, 200-250mm thick; (5) 28-day cure with daily wetting; (6) tiled or pebble interior finish; (7) coping (bullnose tile, travertine or precast); (8) equipment install, plumbing, fence and commissioning. Total 16-26 weeks." }
    },
    {
      "@type": "Question",
      "name": "What interior finishes are available on a concrete pool?",
      "acceptedAnswer": { "@type": "Answer", "text": "Three main categories. Pebblecrete (mid-budget, $80-$140/m², natural-looking, the modern equivalent of 90s pebble), quartz finishes like StoneScapes or PebbleSheen ($120-$200/m², finer texture, premium feel) and fully tiled interior ($250-$500+/m² depending on tile, the ultimate finish). Glass-bead pebble is the current trend — gives a luminous shimmer in sunlight. We bring samples to the site visit so you can see them in your light." }
    },
    {
      "@type": "Question",
      "name": "Do concrete pools crack?",
      "acceptedAnswer": { "@type": "Answer", "text": "Properly engineered concrete pools should not crack structurally for 50+ years. Hairline surface cracks in the interior finish (pebble, plaster, quartz) happen occasionally and are cosmetic, not structural — they can be patched in a renovation cycle. Structural cracking happens when builders cut corners on the reactive-clay engineering: insufficient piers, undersized reo, no consideration of soil class. We bore piers to 1.5-2.4m, use full 8mm reo cages, and engage a registered structural engineer for the shell design. Our pools don't crack." }
    },
    {
      "@type": "Question",
      "name": "Can you build a concrete pool on a sloping block?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — concrete is actually better than fibreglass for slopes. We can step the pool into the slope with one or more retaining walls engineered as part of the pool structure, or set the deep end above ground with a feature stone wall. Sloping concrete builds add roughly $8K-$18K to a flat-block price, mostly for the retaining engineering. Hampton Park and the rural-residential parts of Berwick get a lot of these." }
    },
    {
      "@type": "Question",
      "name": "How long does a concrete pool build take in Berwick?",
      "acceptedAnswer": { "@type": "Answer", "text": "From contract sign to first swim: 16-26 weeks realistic. Permit and engineering 6-8 weeks. Excavation 1-2 weeks. Steel and shotcrete 1 week. Cure 4 weeks (non-negotiable — concrete reaches design strength at 28 days). Interior finish 1-2 weeks. Tiling and coping 2-3 weeks. Paving, fence and equipment 2-3 weeks. Casey winter (June-August) regularly adds 2-4 weeks of weather delay on the dig — we plan around it." }
    }
  ]
};
---
<Layout
  title="New Concrete Pool Berwick | Custom Shotcrete Pools | (03) 9003 0108"
  description="Custom concrete pool builds for Berwick, Cranbourne, Narre Warren, Hampton Park, Endeavour Hills. Sprayed shotcrete, reinforced reactive-clay engineering, tiled or pebble finish. $50K-$90K typical. 50-year structural life."
  canonical="https://berwickpools.com.au/services/new-concrete-pool/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow">The 50-year option</span>
      <h1>New concrete pools in <span class="accent">Berwick &amp; the City of Casey</span>.</h1>
      <p class="hero-sub">
        Fully custom sprayed-shotcrete pools, designed to your block and your life.
        Any shape, any depth, any interior finish. Reactive-clay engineering done
        properly with bored piers. Tiled coping, pebble or full-tile interior.
        Built once, swims for 50+ years.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
        <a class="btn btn-ghost" href="/quote/">Book a free consultation</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <h2>Concrete pool builds &mdash; the detail.</h2>
      <div style="max-width: 65rem;">
        <h3>What you get for $50K&ndash;$90K.</h3>
        <p>
          A standard 8m &times; 4m custom concrete pool with bored-pier engineering,
          200mm sprayed-shotcrete shell, mid-tier pebble interior, bullnose tile
          waterline, travertine or precast coping, salt chlorinator, variable-speed
          pump, cartridge filter, AS 1926 fence integration and full permit
          handling. Add $8K&ndash;$15K for an integrated spa, $5K&ndash;$10K for
          in-floor cleaning, $4K&ndash;$8K for premium tiled interior, $3K&ndash;$6K
          for full LED lighting + automation. The base price assumes a flat block
          with reasonable truck access &mdash; sloping or access-limited blocks
          add $8K&ndash;$18K.
        </p>

        <h3 style="margin-top: 2rem;">Materials and methods we use.</h3>
        <ul>
          <li><strong>Bored concrete piers</strong> &mdash; 350mm diameter, 1.5&ndash;2.4m deep, 6 to 12 piers per pool depending on shell size and soil class. The non-negotiable foundation under reactive Casey clay.</li>
          <li><strong>Reinforcing steel</strong> &mdash; full 8mm or 10mm cage at 200mm centres, tied to pier starter bars. Engineer-certified design, not eyeball spacing.</li>
          <li><strong>Sprayed shotcrete shell</strong> &mdash; 200&ndash;250mm thick, applied wet-mix from a pump-fed nozzle. Denser and more uniform than hand-poured concrete.</li>
          <li><strong>28-day moist cure</strong> &mdash; daily wet-down, surface kept damp. Concrete only hits design strength at 28 days. We don&rsquo;t shortcut it.</li>
          <li><strong>Interior finish options</strong> &mdash; pebblecrete, quartz (PebbleSheen, StoneScapes), or full-tile (porcelain mosaic or glass). Samples on site.</li>
          <li><strong>Coping options</strong> &mdash; bullnose tile, precast concrete, natural travertine, or full-thickness stone. We bring physical samples.</li>
        </ul>

        <h3 style="margin-top: 2rem;">Build timeline.</h3>
        <p>
          16&ndash;26 weeks from contract to first swim. Permit 6&ndash;8 weeks
          (we lodge while you finalise design). Excavation 1&ndash;2 weeks
          (weather-dependent on Casey clay). Piers + steel + shotcrete 2&ndash;3
          weeks. <strong>Mandatory 28-day cure.</strong> Interior finish 1&ndash;2
          weeks. Tiling and coping 2&ndash;3 weeks. Paving, fence and equipment
          install 2&ndash;3 weeks. Final certification and fill 1 week.
        </p>

        <h3 style="margin-top: 2rem;">Why concrete over fibreglass.</h3>
        <ul>
          <li><strong>Shape freedom.</strong> Wet-edge spillover, beach entry, L-shape, integrated spa, lap-pool-with-shallow-end. None of these come in a fibreglass shell.</li>
          <li><strong>Depth freedom.</strong> Most fibreglass shells max out at 1.85m deep. Concrete: as deep as you want, up to 2.5m for diving boards (rare these days but possible).</li>
          <li><strong>50-year structural life.</strong> The shell outlasts your time in the house. Fibreglass is excellent for 25&ndash;35 years.</li>
          <li><strong>Tiled-finish look.</strong> Nothing else looks like a properly tiled concrete pool. Fibreglass gelcoat is great but it&rsquo;s a different aesthetic.</li>
          <li><strong>Easier to renovate later.</strong> Replaster, retile or refinish in 25 years &mdash; same shell, fresh look. Fibreglass is harder to refinish.</li>
        </ul>

        <h3 style="margin-top: 2rem;">When concrete is the wrong call.</h3>
        <p>
          Honest: if your block is flat, you want a standard rectangle or kidney
          shape, and you don&rsquo;t need a depth beyond 1.85m, fibreglass is
          probably better value. You save $15K&ndash;$25K and 10&ndash;15 weeks
          of build time. We&rsquo;ll say so at the site visit. We&rsquo;re
          builders, not concrete-pool salespeople &mdash; we build both formats
          equally happily.
        </p>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="section-inner">
      <h2>Where we work.</h2>
      <div class="areas-grid">
        <a class="area-pill" href="/berwick/">Berwick</a>
        <a class="area-pill" href="/cranbourne/">Cranbourne</a>
        <a class="area-pill" href="/narre-warren/">Narre Warren</a>
        <a class="area-pill" href="/hampton-park/">Hampton Park</a>
        <a class="area-pill" href="/endeavour-hills/">Endeavour Hills</a>
        <a class="area-pill" href="/city-of-casey/">All City of Casey</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="cta-block">
        <h2>Free concrete pool consultation.</h2>
        <p>Shape and finish samples on-site. Honest concrete-vs-fibreglass advice. Fixed quote in 7&ndash;10 days.</p>
        <div class="hero-actions" style="justify-content:center;">
          <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
          <a class="btn btn-ghost" href="/quote/">Book online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
