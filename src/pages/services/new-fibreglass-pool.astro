---
import Layout from '../../layouts/Layout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "New Fibreglass Pool Install",
  "serviceType": "Pre-formed fibreglass swimming pool shell supply and installation",
  "provider": {
    "@type": "GeneralContractor",
    "name": "Berwick Pools",
    "telephone": "+61390030108"
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "City of Casey" },
    { "@type": "City", "name": "Berwick" },
    { "@type": "City", "name": "Cranbourne" },
    { "@type": "City", "name": "Narre Warren" },
    { "@type": "City", "name": "Hampton Park" },
    { "@type": "City", "name": "Endeavour Hills" }
  ],
  "description": "Australian-made pre-formed fibreglass swimming pool shells supplied and installed for Berwick and the wider City of Casey. Compass, Leisure, Narellan, Plungie. 25-year structural warranty. Faster install and lower cost than concrete on flat blocks with reasonable side or front access.",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "AUD",
    "priceRange": "$35,000-$60,000",
    "description": "Typical 8m × 4m fibreglass pool installed, including shell, crane-in, sand bed, plumbing, equipment, coping and commissioning. Paving and fencing additional."
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why choose a fibreglass pool over concrete?",
      "acceptedAnswer": { "@type": "Answer", "text": "Three reasons: cost (typically 30-40% cheaper than custom concrete for the same footprint), speed (8-14 weeks total vs 16-26 for concrete), and smoothness (gelcoat surface is non-abrasive on feet and easier to clean than pebble). Quality Australian-made shells from Compass, Leisure, Narellan and Plungie carry 25-year structural warranties. For a flat block with reasonable access and a standard shape, fibreglass is usually the smarter call." }
    },
    {
      "@type": "Question",
      "name": "Which fibreglass pool brands do you install?",
      "acceptedAnswer": { "@type": "Answer", "text": "We're independent — we install whichever shell suits your block and budget. Most common: Compass Pools (Composite Armour shell, ceramic core, 25-year structural), Leisure Pools (Vacuum-infused composite, 25-year), Narellan Pools (well-established, broad range), Plungie (precast concrete plunge alternative). We bring sample swatches to the site visit so you can see colours in your light. The shell choice is your call — we tell you the pros and cons of each." }
    },
    {
      "@type": "Question",
      "name": "How does the crane installation work?",
      "acceptedAnswer": { "@type": "Answer", "text": "On install day a crane truck parks on your street, lifts the shell over the house (or down the side return if access allows) and lowers it into the prepared excavation. The lift itself takes 20-40 minutes. We pre-set the screeded sand bed the day before, level the shell exactly, plumb the skimmer and returns immediately, then backfill with crushed rock around the shell as we fill the pool with water in stages. The backfill must happen as the water goes in — that's the standard against shell deformation. Full install day to commissioning: 5-10 working days." }
    },
    {
      "@type": "Question",
      "name": "What's the minimum access required for a fibreglass shell?",
      "acceptedAnswer": { "@type": "Answer", "text": "For shells up to 8m × 4m, we need either: 3.5m minimum clear width down the side return (rare on standard Casey blocks), or 8m+ clear airspace over the house roofline for a crane-over lift (achievable from most front yards but blocked by some overhead power lines, large eucalypts or two-storey neighbours). We check access at the site visit with a tape and an eyes-up look — if access fails, the answer is concrete (sprayed in place, no shell to manoeuvre)." }
    },
    {
      "@type": "Question",
      "name": "Will the fibreglass shell shift or pop out of the ground?",
      "acceptedAnswer": { "@type": "Answer", "text": "Not if it's installed properly. The risk is real but preventable. We screed a deep crushed-rock sand bed under the shell, install a 100mm subsoil ag-drain on the downhill side plumbed to a legal point of discharge, and backfill with compacted crushed rock (never sand alone — sand washes away in heavy rain). The shell is never allowed to sit empty after install — we fill and backfill simultaneously. Done this way, the shell stays where it's put for the full warranty period and beyond." }
    },
    {
      "@type": "Question",
      "name": "Can you change the colour or shape of a fibreglass pool?",
      "acceptedAnswer": { "@type": "Answer", "text": "Colour yes — most manufacturers offer 6-12 gelcoat colour options. Shape no — you pick from the manufacturer's catalogue of pre-formed shells. Typical sizes: 6m, 7m, 8m, 9m and 10m lengths in standard rectangle, kidney, freeform and lap-pool shapes. If you want a truly custom shape, depth or feature, that's a concrete build, not fibreglass. Most owners find a stock shell that works fine — we have catalogues from 4-5 manufacturers covering 60+ shapes." }
    }
  ]
};
---
<Layout
  title="New Fibreglass Pool Berwick | Compass, Leisure, Narellan | (03) 9003 0108"
  description="Fibreglass pool installs for Berwick, Cranbourne, Narre Warren, Hampton Park, Endeavour Hills. Australian-made shells — Compass, Leisure, Narellan, Plungie. 25-year structural warranty. $35K-$60K installed. 8-14 week turnaround."
  canonical="https://berwickpools.com.au/services/new-fibreglass-pool/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow">Faster, cheaper, still premium</span>
      <h1>New fibreglass pools in <span class="accent">Berwick &amp; the City of Casey</span>.</h1>
      <p class="hero-sub">
        Australian-made pre-formed fibreglass shells from Compass, Leisure, Narellan
        and Plungie. 25-year structural warranty. Smoother on feet, faster to build
        and 30&ndash;40% cheaper than equivalent concrete. The default choice for
        flat Casey blocks with reasonable crane access.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
        <a class="btn btn-ghost" href="/quote/">Book a free consultation</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <h2>Fibreglass pool installs &mdash; the detail.</h2>
      <div style="max-width: 65rem;">
        <h3>What you get for $35K&ndash;$60K.</h3>
        <p>
          A standard 7&ndash;8m &times; 3.5&ndash;4m Australian-made fibreglass
          shell delivered to your block, crane-installed onto a properly screeded
          and drained sand bed, plumbed up with two skimmers, returns and a
          main drain, fitted with a variable-speed pump, cartridge filter and
          salt chlorinator. Includes precast concrete coping or bullnose paver
          edge, equipment slab and AS 1926 fence integration. Paving the
          surround typically adds $4K&ndash;$10K depending on material (concrete
          stamped, travertine, large-format porcelain). Fencing $6K&ndash;$12K
          depending on glass vs aluminium.
        </p>

        <h3 style="margin-top: 2rem;">The shells we install.</h3>
        <ul>
          <li><strong>Compass Pools</strong> &mdash; Composite Armour shell with ceramic core, vacuum-infused for void-free construction. 25-year structural warranty. Wide range, premium tier.</li>
          <li><strong>Leisure Pools</strong> &mdash; Vacuum-infused composite with vinyl ester resin, full ceramic core, 25-year structural warranty. Strong colour range.</li>
          <li><strong>Narellan Pools</strong> &mdash; The Australian classic. 50+ shapes, mid-to-premium tier, established warranty network, dealer-installed.</li>
          <li><strong>Plungie</strong> &mdash; Pre-cast concrete shell (not fibreglass strictly but installed the same way). For plunge-pool sizes 3&ndash;5m, premium finish, near-zero install complexity.</li>
        </ul>
        <p>
          We&rsquo;re manufacturer-independent &mdash; we install whichever
          shell suits your block, budget and shape preference. The site visit
          includes physical colour-swatch samples for at least two brands.
        </p>

        <h3 style="margin-top: 2rem;">Install process.</h3>
        <ol>
          <li><strong>Site prep:</strong> excavation to design depth + 200mm working clearance, with allowance for over-dig at the corners. Spoil carted offsite. 1&ndash;2 days.</li>
          <li><strong>Sand bed:</strong> 200&ndash;300mm of screeded crushed rock (not sand alone), laser-levelled to the shell&rsquo;s base profile. Subsoil ag-drain on the downhill side, plumbed to a legal discharge point.</li>
          <li><strong>Crane install:</strong> shell craned in (over the house or down the side return) and set into position. 20&ndash;40 minutes for the lift.</li>
          <li><strong>Plumbing:</strong> skimmers, returns and main drain plumbed immediately while access is clear.</li>
          <li><strong>Backfill + fill:</strong> 100mm crushed rock backfilled around the shell as water fills the pool in stages. Critical &mdash; backfill must happen with water in the pool, not before.</li>
          <li><strong>Equipment + coping:</strong> equipment slab, pump and filter install, salt cell wiring, coping laid, paving and fence behind.</li>
          <li><strong>Commission + certify:</strong> AS 1926 fence inspection, water balance, automation programming, register lodgement.</li>
        </ol>

        <h3 style="margin-top: 2rem;">Build timeline.</h3>
        <p>
          8&ndash;14 weeks from contract to first swim. Permit 4&ndash;6 weeks
          (we lodge while shell is being manufactured). Shell manufacture 2&ndash;6
          weeks (depending on brand and colour). On-site install 2&ndash;3 weeks
          (dig, bed, crane, plumb, backfill). Coping and paving 1 week. Fence
          and equipment 1 week. Compared to 16&ndash;26 weeks for concrete &mdash;
          this is the speed advantage.
        </p>

        <h3 style="margin-top: 2rem;">When fibreglass is the right call.</h3>
        <ul>
          <li><strong>Flat block</strong> with reasonable side or crane-over access.</li>
          <li><strong>Standard shape</strong> works for you &mdash; rectangle, kidney, freeform, lap, plunge.</li>
          <li><strong>1.0&ndash;1.85m depth</strong> covers your needs (most family pools).</li>
          <li><strong>Cost-conscious</strong> &mdash; save $15K&ndash;$25K vs equivalent concrete and put it into paving and landscaping.</li>
          <li><strong>Faster build</strong> matters &mdash; you want to swim this summer, not next.</li>
        </ul>

        <h3 style="margin-top: 2rem;">When concrete is the better call.</h3>
        <p>
          Sloping blocks, awkward shapes, wet-edge or feature-wall designs,
          depth beyond 1.85m, or just the visual difference of a fully tiled
          interior. We&rsquo;ll say so at the site visit if your block fits the
          concrete profile better. <a href="/services/new-concrete-pool/">See
          our new concrete pool builds &rarr;</a>
        </p>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="section-inner">
      <h2>Where we work.</h2>
      <div class="areas-grid">
        <a class="area-pill" href="/berwick/">Berwick</a>
        <a class="area-pill" href="/cranbourne/">Cranbourne</a>
        <a class="area-pill" href="/narre-warren/">Narre Warren</a>
        <a class="area-pill" href="/hampton-park/">Hampton Park</a>
        <a class="area-pill" href="/endeavour-hills/">Endeavour Hills</a>
        <a class="area-pill" href="/city-of-casey/">All City of Casey</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="cta-block">
        <h2>Free fibreglass pool consultation.</h2>
        <p>Brand and colour samples on-site. Access check included. Fixed quote in 7&ndash;10 days.</p>
        <div class="hero-actions" style="justify-content:center;">
          <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
          <a class="btn btn-ghost" href="/quote/">Book online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
